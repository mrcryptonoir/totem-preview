# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.

# ─── WebLLM (default backend) ───────────────────────────────────────────────
# Override the default in-browser model (see https://mlc.ai/models for IDs).
# NEXT_PUBLIC_WEBLLM_MODEL=Qwen3.5-2B-q4f16_1-MLC

# ─── UI development ──────────────────────────────────────────────────────────
# Set to "true" to skip the loading screen and render the chat UI immediately.
# Never set this in production.
# NEXT_PUBLIC_DEMO_MODE=true

# ─── GitHub Pages deployment ─────────────────────────────────────────────────
# Set to /repo-name when deploying to a GitHub Pages project page
# (e.g. username.github.io/repo-name). Leave unset for Cloudflare / custom domain.
# BASE_PATH=/totem-preview
